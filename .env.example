# Copy this file to .env and fill in your values.

RPC_URL=https://your-solana-rpc
JUPITER_API_KEY=your-jupiter-api-key

# Live trading wallet config. Required for `sniper-bot.js`.
# PRIVATE_KEY=your-wallet-private-key
# PRIVATE_KEY_PATH=./wallet.json

BUY_AMOUNT_SOL=0.05
SCAN_INTERVAL_MS=5000
SLIPPAGE_BPS=150
MAX_OPEN_POSITIONS=10
MAX_BUYS_PER_SCAN=1
MAX_CANDIDATES_PER_SCAN=10

DRY_RUN=true
INITIAL_PAPER_SOL=2
STATE_FILE=./paper-sniper-state.json

MIN_LIQUIDITY_USD=1500
MIN_ORGANIC_SCORE=0
MIN_HOLDER_COUNT=10
MIN_BUYS_5M=2
MIN_POOL_AGE_SECONDS=5
SURVIVAL_DELAY_SECONDS=30
MIN_SURVIVAL_MOMENTUM=1.05
MAX_PRICE_DUMP_PCT=20
MAX_LIQUIDITY_DRAWDOWN_PCT=15
PERFORMANCE_CHECK_SECONDS=75
PERFORMANCE_MIN_MOMENTUM=1.05
MAX_CANDIDATE_AGE_MINUTES=30
MIN_SOCIAL_LINKS=0
MAX_AUDIT_TOP_HOLDERS_PCT=60
MAX_TOKEN_ACCOUNT_TOP1_PCT=90
MAX_TOKEN_ACCOUNT_TOP5_PCT=98
MAX_FDV_TO_LIQUIDITY=80
MAX_MEME_FDV_USD=10000000
ALLOW_VERIFIED_TOKENS=true
MIN_CANDIDATE_SCORE=45
TRAILING_STOP_ACTIVATION_MULTIPLE=2.5
TRAILING_STOP_DRAWDOWN_PCT=0.25
MAX_HOLD_MINUTES=240
TIME_EXIT_MIN_MULTIPLE=1.25
MIN_HOLD_TIME_SECONDS=60
STOP_LOSS_PCT=0.40
LIQUIDITY_COLLAPSE_THRESHOLD_USD=750
LIQUIDITY_COLLAPSE_THRESHOLD_RATIO=0.10

# Confidence-based hold strategy for the remaining 25% balance
HOLD_DURATION_HIGH_CONFIDENCE_MINUTES=10
HOLD_DURATION_LOW_CONFIDENCE_MINUTES=5
RECHECK_PRICE_DROP_PCT=15
# Optional risk APIs
# GOPLUS_ACCESS_TOKEN=your-goplus-token
# BUBBLEMAPS_API_KEY=your-bubblemaps-key
MIN_BUBBLEMAPS_SCORE=60
MAX_BUBBLEMAPS_LARGEST_CLUSTER_SHARE=0.20

# Paper analytics files
# TRADE_JOURNAL_FILE=./paper-trade-journal.jsonl
# PERFORMANCE_STATS_FILE=./paper-performance-stats.json

# `sniper-bot.js` is live-trading only.
# `paper-sniper-bot.js` is paper-trading only.

# Optional custom .env path support:
# ENV_FILE=./.env
