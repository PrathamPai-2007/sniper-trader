# ==========================================
# Veloci-Buy - Environment Template
# ==========================================

# --- 1. Network & APIs ---
# Your Solana RPC endpoint (Must support Websockets for real-time discovery)
RPC_URL=https://your-solana-rpc
# Optional: Override the derived WebSocket URL
# WS_RPC_URL=wss://your-solana-ws

# Jupiter API (Required for swaps and price data)
JUPITER_API_KEY=your-jupiter-api-key
JUPITER_BASE_URL=https://api.jup.ag

# Security APIs (Optional but recommended)
# GOPLUS_ACCESS_TOKEN=your-goplus-token
GOPLUS_BASE_URL=https://api.gopluslabs.io/api/v1
# BUBBLEMAPS_API_KEY=your-bubblemaps-key
BUBBLEMAPS_BASE_URL=https://api.bubblemaps.io

# --- 2. Wallet & Trading Mode ---
# Strategy preset: conservative, standard, or aggressive
STRATEGY=standard
# PRIVATE_KEY: Your wallet's private key (Base58 encoded)
# PRIVATE_KEY_PATH: Alternative path to a keypair.json file
# PRIVATE_KEY=your-wallet-private-key
# PRIVATE_KEY_PATH=./wallet.json

# If true, simulate transactions without broadcasting them to the network
DRY_RUN=true
# Required explicit arming switch before real live swaps can start
LIVE_TRADING_ENABLED=false
# If true, uses a local virtual balance for simulation instead of real SOL
PAPER_TRADING=true
# Starting SOL balance for paper trading mode
INITIAL_PAPER_SOL=1
# If true, uses the high-performance Jupiter SDK for execution
USE_JUPITER_SDK=false

# --- 3. Position Management ---
# Amount of SOL to spend on each new trade
BUY_AMOUNT_SOL=0.05
# Maximum swap slippage in basis points (500 = 5%)
SLIPPAGE_BPS=500
# Maximum number of concurrent open positions
MAX_OPEN_POSITIONS=10
# Maximum new buys per discovery scan cycle
MAX_BUYS_PER_SCAN=2
# Maximum candidates to evaluate in a single discovery scan
MAX_CANDIDATES_PER_SCAN=15
# Legacy/shared audit concurrency fallback
MAX_CONCURRENT_AUDITS=10
# Light candidate audit worker slots
SCAN_PARALLELISM_LIGHT=10
# Full/final audit worker slots
SCAN_PARALLELISM_HEAVY=4
# GoPlus owner lookup worker slots
OWNER_AUDIT_PARALLELISM=4
# Per-mint price fallback worker slots
PRICE_FALLBACK_PARALLELISM=6
# Temporary concurrency floor during timeout/rate-limit bursts
PARALLELISM_MIN_FACTOR=0.5
# Number of recent scan tasks used for adaptive backpressure
ERROR_RATE_WINDOW=20
# Error rate that triggers temporary concurrency reduction
BACKPRESSURE_ERROR_RATE_THRESHOLD=0.30
# Attempts for full-audit mint/account RPC indexing before deferring
MINT_SIGNAL_MAX_ATTEMPTS=3
# Base delay between mint/account indexing attempts
MINT_SIGNAL_RETRY_DELAY_MS=750
# Delay before retrying a final audit that hit RPC indexing lag
RPC_INDEXING_RETRY_DELAY_MS=15000

# --- 4. Discovery & Global Filters ---
# Main loop interval for discovery scans
SCAN_INTERVAL_MS=5000
# Backup REST poll interval for new tokens via Jupiter /tokens/v2/recent.
# WebSocket subscriptions handle real-time discovery, so this is just a safety net.
# Default is 30s — lowering it significantly increases Jupiter API usage.
DISCOVERY_POLL_INTERVAL_MS=30000
# Discovery WebSocket enabled for near-instant detection of new tokens
DISCOVERY_WS_ENABLED=true
# Toggle specific DEX discovery (Reduces WebSocket noise)
DISCOVERY_PUMP_ENABLED=true
DISCOVERY_RAYDIUM_ENABLED=true
DISCOVERY_METEORA_ENABLED=true
# Debounce time for WebSocket signals to batch multiple initializations
DISCOVERY_WS_DEBOUNCE_MS=750
# Reconnect websocket subscriptions if they go stale
WEBSOCKET_WATCHDOG_INTERVAL_MS=30000
WEBSOCKET_STALE_THRESHOLD_MS=90000

# Global Liquidity floor in USD
MIN_LIQUIDITY_USD=750
# Minimum organic score from Jupiter/On-chain heuristics
MIN_ORGANIC_SCORE=0
# Minimum unique holder count
MIN_HOLDER_COUNT=2
# Maximum % of supply held by top holders
MAX_AUDIT_TOP_HOLDERS_PCT=95
# Maximum % of supply held by largest token account
MAX_TOKEN_ACCOUNT_TOP1_PCT=70
# Maximum % of supply held by top 5 token accounts
MAX_TOKEN_ACCOUNT_TOP5_PCT=85
# FDV/liquidity and maximum meme FDV filters
MAX_FDV_TO_LIQUIDITY=80
MAX_MEME_FDV_USD=10000000
# Comma-separated keyword override for memecoin heuristics
# MEME_KEYWORDS=ai,ape,bonk,cat,dog,pepe,pump,sol
# Minimum buys in the last 5 minutes
MIN_BUYS_5M=1
# Minimum seconds since pool creation before evaluation
MIN_POOL_AGE_SECONDS=0
# Maximum age of a candidate in minutes to be considered "fresh"
MAX_CANDIDATE_AGE_MINUTES=30
# Minimum number of social links (X, TG, Website)
MIN_SOCIAL_LINKS=0
# Allow tokens that have verified metadata on Jupiter
ALLOW_VERIFIED_TOKENS=true
# Minimum overall audit score (0-100) to pass entry
MIN_CANDIDATE_SCORE=60

# --- 5. Audit & Momentum Engine ---
# Initial observation window for momentum verification
SURVIVAL_DELAY_SECONDS=10
# Seconds allowed for the Final Audit fact-check
FINAL_AUDIT_SECONDS=5
# Required price gain (1.00x) during the survival delay
MIN_SURVIVAL_MOMENTUM=0.98
# Minimum breakout multiplier required (1.001 = 0.1% gain)
MIN_BREAKOUT_MULTIPLIER=1.000
# Maximum price dump (%) allowed during survival delay
MAX_PRICE_DUMP_PCT=20
# Maximum parabolic growth (%) - avoids "top-sniping"
MAX_SURVIVAL_GROWTH_PCT=300
# Maximum liquidity drawdown (%) allowed during survival delay
MAX_LIQUIDITY_DRAWDOWN_PCT=25
# Minimum ratio of positive vs negative price snapshots (Consistency)
MIN_MOMENTUM_CONSISTENCY=0.45
# Maximum price range (%) for exhaustion detection (Flatline filter)
MAX_EXHAUSTION_RANGE_PCT=1.6
# Minimum acceleration factor between segments
MIN_ACCELERATION_FACTOR=0.16
# Max allowed sell pressure increase (%) during delay
MAX_SELL_PRESSURE_INCREASE_PCT=100
# Optional borderline candidate recheck controls
BORDERLINE_RECHECK_ENABLED=true
BORDERLINE_RECHECK_MIN_DELAY_MS=10000
BORDERLINE_RECHECK_MAX_DELAY_MS=20000
BORDERLINE_RECHECK_MAX_ATTEMPTS=3
BORDERLINE_THRESHOLD_BUFFER_PCT=20
# High confidence score threshold for take-profit planning
HIGH_GROWTH_CONFIDENCE_SCORE=70

# --- 6. Risk Management (Exits) ---
# Trailing Stop-Loss drawdown percentage (0.20 = 20% drop from peak)
TRAILING_STOP_DRAWDOWN_PCT=0.20
# Static Stop-Loss percentage (0.2 = 20% drop from entry)
STOP_LOSS_PCT=0.2

# Milestone Take-Profit: Sell 60% of position at 1.5x gain
TAKE_PROFIT_MULTIPLES=1.5
TAKE_PROFIT_FRACTION=0.60

# Early Performance Guard: Active in first X seconds
EARLY_PERFORMANCE_GUARD_SECONDS=10
# Exit 60% if price drops by Y% in the guard window
EARLY_PERFORMANCE_DROP_PCT=10
EARLY_PERFORMANCE_SELL_PCT=60

# Secondary Performance Audit (Holding check)
PERFORMANCE_CHECK_SECONDS=75
PERFORMANCE_MIN_MOMENTUM=1.05

# Time-based exit rules
MIN_HOLD_TIME_SECONDS=60
MAX_HOLD_MINUTES=60
TIME_EXIT_MIN_MULTIPLE=1.25

# Liquidity Safety
LIQUIDITY_COLLAPSE_THRESHOLD_USD=750
LIQUIDITY_COLLAPSE_THRESHOLD_RATIO=0.25

# --- 7. Priority Fees (Micro-Lamports) ---
PRIORITY_FEE_BASE_MICRO_LAMPORTS=25000
PRIORITY_FEE_MAX_MICRO_LAMPORTS=5000000
PRIORITY_FEE_PANIC_MULTIPLIER=2.0
PRIORITY_FEE_PERCENTILE=75

# --- 8. Security & Third-Party Audit ---
# GoPlus Security is enabled when GOPLUS_ACCESS_TOKEN is set.
# BubbleMaps
MIN_BUBBLEMAPS_SCORE=60
MAX_BUBBLEMAPS_LARGEST_CLUSTER_SHARE=0.20

# --- 9. Re-entry & Cooling ---
# Minutes to wait before re-evaluating the same mint after exit
COOL_DOWN_MINUTES=20
# Seconds to wait before re-evaluating tokens with low holder count
HOLDER_COUNT_WAITLIST_SECONDS=60
# Minutes to pause discovery if win-rate drops too low (Mood system)
MOOD_PAUSE_DURATION_MINUTES=60
# Re-entry gate: Price must be +/- X% from last exit
REENTRY_DIP_PCT=15
REENTRY_BREAKOUT_PCT=20
# Optional hold duration tuning
HOLD_DURATION_HIGH_CONFIDENCE_MINUTES=10
HOLD_DURATION_LOW_CONFIDENCE_MINUTES=5
RECHECK_PRICE_DROP_PCT=15

# --- 10. Persistence & Logging ---
# If true, market-sell all open positions when the bot is stopped (SIGINT/SIGTERM)
CLOSE_POSITIONS_ON_SHUTDOWN=true
# Optional notifications
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# TELEGRAM_CHAT_ID=your-telegram-chat-id
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# Path to state file (auto-generated in logs/ if empty)
# STATE_FILE=./bot-state.json
# Path to custom log file
# LOG_FILE=./bot.log
# Path to scanned token JSONL file
# SCANNED_TOKENS_FILE=./scanned-memecoins.jsonl
